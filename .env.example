# Override the content-addressable source store location.
# Default: platformdirs.user_data_dir("tool_cv_corpus") / "sources"
# CV_CORPUS_SOURCE_STORE=/path/to/store

# Override the default generation model (finding E4).
# CV_CORPUS_MODEL=claude-sonnet-4-6

# Primary LLM provider credentials (Anthropic by default)
# ANTHROPIC_API_KEY=

# Optional alternates
# OPENAI_API_KEY=
